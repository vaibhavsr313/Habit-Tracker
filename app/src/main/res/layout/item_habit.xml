<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="12dp"
    app:cardBackgroundColor="#1A1A1A"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Top row: color strip | name + streak | delete | toggle -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <View
                android:id="@+id/colorStrip"
                android:layout_width="5dp"
                android:layout_height="44dp"
                android:layout_marginEnd="12dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvHabitName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:fontFamily="@font/montserrat_semibold"
                    android:textSize="16sp"
                    android:textStyle="bold" />

               <LinearLayout
                   android:layout_width="wrap_content"
                   android:layout_height="wrap_content"
                   android:orientation="horizontal">

                   <TextView
                       android:id="@+id/tvStreak"
                       android:layout_width="wrap_content"
                       android:layout_height="wrap_content"
                       android:textColor="#888888"
                       android:fontFamily="@font/montserrat_semibold"
                       android:textSize="12sp"
                       android:layout_marginTop="2dp" />

                   <TextView
                       android:id="@+id/tvActiveDays"
                       android:layout_width="wrap_content"
                       android:layout_height="wrap_content"
                       android:fontFamily="@font/montserrat_semibold"
                       android:textColor="#888888"
                       android:textSize="12sp"
                       android:layout_marginTop="2dp" />

               </LinearLayout>

            </LinearLayout>

            <!-- Delete button -->
            <ImageButton
                android:id="@+id/btnDelete"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@android:drawable/ic_menu_delete"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:layout_marginEnd="8dp"
                android:contentDescription="Delete habit"
                app:tint="#666666" />

            <!-- Done toggle -->
            <View
                android:id="@+id/btnToggle"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <!-- Heatmap scrollable -->
        <HorizontalScrollView
            android:id="@+id/heatmapScroll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:scrollbars="none"
            android:overScrollMode="never">

            <com.example.habittra.ui.home.HeatmapView
                android:id="@+id/heatmapView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

        </HorizontalScrollView>

    </LinearLayout>
</androidx.cardview.widget.CardView>